# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.pytest_cache/

# Env / secrets (NEVER commit)
.env
.env.local
.env.*.local
*.key
*.pem
ibkr_credentials*

# Kill switch lock (created at 10% drawdown; human-only deletion -- never commit)
.killed

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
*~

# Local scratch / transient plans (never commit -- canonical plans go in K2Bi-Vault/wiki/planning/)
.tmp/

# Pending-sync mailbox is a directory of session-defer entries -- contents not committed
.pending-sync/*
!.pending-sync/.gitkeep

# Built artifacts
dist/
build/
*.log
# Runtime log dir -- gitignored so Codex working-tree pre-flight does not
# EISDIR on it (mirrors K2B 9ff5dfc fix for plans/Parked + plans/Shipped)
logs/

# Claude Code runtime artifacts (local-only state, never committed)
.claude/*.lock
.claude/settings.local.json
.claude/worktrees/

# Codex/agent runtime artifacts (local-only state, never committed)
.agents/
.codex/

# MiniMax review archive (local-only -- raw responses, prompts, usage log)
.minimax-reviews/

# Unified review-runner archive (heartbeat log + state JSON per job)
.code-reviews/

# Sync sentinel (last-successfully-synced HEAD SHA) -- per-machine state
# written by scripts/lib/deploy_config.py record-sync; never deployed
.sync-state/

# Kimi handoff job specs (local only) -- with one tracked exception:
# .kimi/post-build-hook.sh is the per-repo post-build hook contract
# from the kimi-handoff convention; it must travel with the repo so a
# fresh clone runs the same propagation step on /ship. Use .kimi/*
# (glob) rather than .kimi/ (directory) so the negation can take
# effect at the file level — git skips negation when the parent
# directory itself is ignored.
.kimi/*
!.kimi/post-build-hook.sh
